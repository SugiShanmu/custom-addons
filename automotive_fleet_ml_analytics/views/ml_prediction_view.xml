<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- 1. LIST VIEW - Table of prediction result  -->
        <record id="view_ml_prediction_tree" model="ir.ui.view">
            <field name="name">ml.prediction.tree</field>
            <field name="model">ml.prediction</field>
            <field name="arch" type="xml">
                <tree string="ML Predictions" decoration-success="prediction_type == 'health' and predicted_value >= 80" 
                      decoration-warning="prediction_type == 'health' and predicted_value &lt; 60"
                      decoration-danger="prediction_type == 'health' and predicted_value &lt; 40">
                    <field name="vehicle_id"/>
                    <field name="prediction_type"/>
                    <field name="predicted_value" widget="float" digits="[16,2]"/>
                    <field name="confidence_score" widget="progressbar"/>
                    <field name="model_version"/>
                    <field name="prediction_date"/>
                </tree>
            </field>
        </record>

        <!-- 2. FORM VIEW - Single prediction  detail  -->
        <record id="view_ml_prediction_form" model="ir.ui.view">
            <field name="name">ml.prediction.form</field>
            <field name="model">ml.prediction</field>
            <field name="arch" type="xml">
                <form string="ML Prediction Details">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="open_vehicle" type="object" class="oe_stat_button" icon="fa-car">
                                <field name="vehicle_id" widget="statinfo" string="Vehicle"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="prediction_type" readonly="1"/> Prediction
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="vehicle_id" readonly="1"/>
                                <field name="prediction_date" readonly="1"/>
                                <field name="model_version" readonly="1"/>
                            </group>
                            <group>
                                <field name="predicted_value" readonly="1"/>
                                <field name="confidence_score" widget="percentage" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Input Features">
                                <field name="input_features" readonly="1"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- 3. SEARCH VIEW - Filter -->
        <record id="view_ml_prediction_search" model="ir.ui.view">
            <field name="name">ml.prediction.search</field>
            <field name="model">ml.prediction</field>
            <field name="arch" type="xml">
                <search string="Search Predictions">
                    <field name="vehicle_id"/>
                    <field name="prediction_type"/>
                    <filter string="Fuel" name="filter_fuel" domain="[('prediction_type','=','fuel')]"/>
                    <filter string="Maintenance" name="filter_maintenance" domain="[('prediction_type','=','maintenance')]"/>
                    <filter string="Health" name="filter_health" domain="[('prediction_type','=','health')]"/>
                    <filter string="Today" name="filter_today" domain="[('prediction_date','>=', context_today().strftime('%Y-%m-%d 00:00:00'))]"/>
                    <group expand="0" string="Group By">
                        <filter string="Vehicle" name="group_vehicle" context="{'group_by':'vehicle_id'}"/>
                        <filter string="Type" name="group_type" context="{'group_by':'prediction_type'}"/>
                        <filter string="Date" name="group_date" context="{'group_by':'prediction_date:day'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- 4. ACTION - Menu ku connect panna -->
        <record id="action_ml_prediction" model="ir.actions.act_window">
            <field name="name">Predictions History</field>
            <field name="res_model">ml.prediction</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'search_default_filter_today': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No predictions yet!
                </p>
                <p>
                    Run predictions from Fleet > Vehicles to see results here.
                </p>
            </field>
        </record>
    </data>
</odoo>