<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ML Analytics Group -->
        <record id="group_ml_analytics_user" model="res.groups">
            <field name="name">ML Analytics / User</field>
            <field name="category_id" ref="base.module_category_fleet"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_ml_analytics_manager" model="res.groups">
            <field name="name">ML Analytics / Manager</field>
            <field name="category_id" ref="base.module_category_fleet"/>
            <field name="implied_ids" eval="[(4, ref('group_ml_analytics_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>