<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Inherit Fleet Vehicle Form View -->
        <record id="view_fleet_vehicle_form_accounting" model="ir.ui.view">
            <field name="name">fleet.vehicle.form.accounting</field>
            <field name="model">fleet.vehicle</field>
            <field name="inherit_id" ref="fleet.view_fleet_vehicle_form"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet" position="inside">
                    <group string="Accounting Information">
                        <group>
                            <field name="analytic_account_id"/>
                            <field name="total_maintenance_cost"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>